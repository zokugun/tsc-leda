{
	"name": "@zokugun/tsc-leda",
	"description": "CLI utility compiling (with `tsc`) and preparing TS projects for dual ESM/CJS distribution",
	"version": "0.3.1",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/tsc-leda",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/tsc-leda.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/tsc-leda/discussions/categories/issue-triage"
	},
	"engines": {
		"node": ">=18.20"
	},
	"type": "module",
	"bin": {
		"tsc-leda": "bin/tsc-leda"
	},
	"scripts": {
		"build": "npm run clean && npm run compile:src",
		"clean": "rimraf lib .test",
		"compile:src": "tsc -p src",
		"compile:test": "tsc -p test",
		"lint": "xo",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"test": "vitest run --reporter tree",
		"test:coverage": "vitest run --reporter tree --coverage --coverage.reporter text",
		"test:ui": "vitest --ui --coverage",
		"test:watch": "vitest",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {
		"@zokugun/cli-utils": "^0.1.0",
		"@zokugun/fs-extra-plus": "^0.3.5",
		"@zokugun/is-it-type": "^0.7.0",
		"@zokugun/log-update-plus": "^0.1.0",
		"@zokugun/xtry": "^0.11.0",
		"execa": "^9.6.1",
		"globby": "^14.1.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.7.1",
		"@commitlint/config-conventional": "^19.7.1",
		"@types/node": "^20.14.8",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"fixpack": "^4.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.4",
		"release-it": "^19.2.4",
		"tsc-watch": "^7.2.0",
		"typescript": "^5.7.3",
		"vitest": "^4.0.18",
		"xo": "0.60.0"
	},
	"overrides": {
		"terser-webpack-plugin": {
			"serialize-javascript": "^7.0.3"
		}
	},
	"keywords": [
		"cjs",
		"commonjs",
		"esm",
		"tsc"
	],
	"peerDependencies": {
		"typescript": "*"
	}
}
