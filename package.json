{
	"name": "@zokugun/tsc-leda",
	"description": "CLI utility compiling (with `tsc`) and preparing TS projects for dual ESM/CJS distribution",
	"version": "0.3.2",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/tsc-leda",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/tsc-leda.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/tsc-leda/discussions/categories/issue-triage"
	},
	"engines": {
		"node": ">=18.20"
	},
	"type": "module",
	"bin": {
		"tsc-leda": "bin/tsc-leda"
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib .test",
		"compile:src": "tsc -p src",
		"compile:test": "tsc -p test",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"test": "vitest run --reporter tree",
		"test:coverage": "vitest run --reporter tree --coverage --coverage.reporter text",
		"test:ui": "vitest --ui --coverage",
		"test:watch": "vitest",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {
		"@zokugun/cli-utils": "0.2.1",
		"@zokugun/fs-extra-plus": "0.3.7",
		"@zokugun/is-it-type": "0.8.1",
		"@zokugun/log-update-plus": "0.1.1",
		"@zokugun/xtry": "0.11.4",
		"execa": "9.6.1",
		"globby": "14.1.0",
		"yaml": "2.8.3"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/node": "20.19.39",
		"@vitest/coverage-v8": "4.1.3",
		"@vitest/ui": "4.1.3",
		"@zokugun/fs-extra-plus": "0.3.7",
		"fixpack": "4.0.0",
		"globby": "16.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.0-1",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"vitest": "4.1.3",
		"xo": "0.60.0"
	},
	"keywords": [
		"cjs",
		"commonjs",
		"esm",
		"tsc"
	],
	"peerDependencies": {
		"typescript": "*"
	}
}
